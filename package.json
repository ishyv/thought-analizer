    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
